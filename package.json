{
  "name": "droproom",
  "private": true,
  "type": "module",
  "scripts": {
    "infra:up": "docker compose up -d redis",
    "infra:down": "docker compose down",
    "docker:build": "docker compose -f compose.build.yaml build api web",
    "docker:up": "docker compose -f compose.build.yaml up -d --build",
    "docker:down": "docker compose -f compose.build.yaml down",
    "docker:prod:up": "docker compose -f compose.production.yaml up -d",
    "docker:prod:down": "docker compose -f compose.production.yaml down",
    "dev": "pnpm --parallel --filter @droproom/web --filter @droproom/api dev",
    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml,css,html}": "prettier --write"
  },
  "packageManager": "pnpm@10.32.0"
}
