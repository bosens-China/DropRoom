# 本地开发不需要创建 .env，Redis 默认连接 compose.yaml 的 46379 端口。
#
# 生产环境必须填写下面三项：
NODE_ENV=production
DROPROOM_CORS_ORIGINS=https://your-web.example.com
DROPROOM_REDIS_URL=rediss://username:password@your-redis.example.com:6380

# 其他配置均为可选覆盖：
# DROPROOM_API_PORT=43117
# DROPROOM_REDIS_KEY_PREFIX=droproom
# DROPROOM_STORAGE_ROOT=/var/tmp/droproom
# DROPROOM_LOG_LEVEL=info
# DROPROOM_OPENAPI_ENABLED=true
# DROPROOM_OPENAPI_JSON_PATH=/openapi.json
# DROPROOM_SWAGGER_PATH=/docs
# DROPROOM_ROOM_LIFETIME_MS=86400000
# DROPROOM_DISCONNECT_GRACE_MS=300000
# DROPROOM_UPLOAD_CHUNK_BYTES=2000000
# DROPROOM_MAX_MEMBERS_PER_ROOM=9
# DROPROOM_MAX_TEXT_LENGTH=20000
# DROPROOM_LONG_TEXT_FILE_THRESHOLD=5000
# DROPROOM_MAX_FILES_PER_BATCH=50
# DROPROOM_MAX_BATCH_BYTES=300000000
# DROPROOM_MAX_ROOM_FILE_BYTES=1000000000
# DROPROOM_GLOBAL_FILE_BYTES=30000000000
